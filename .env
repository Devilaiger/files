# ── Telegram ──────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
API_HASH=ae252401c519461df086a9a80adff4b8
API_ID=25916987

# Bot token from @BotFather
BOT_TOKEN=8657166965:AAGzbWD4TlMYqbE54Uk-Gtn2NM5AK9ABY4U

# Session file name (no extension needed)
SESSION_NAME=bot_session

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:       mongodb://localhost:27017
# Atlas:       mongodb+srv://user:password@cluster.mongodb.net
MONGO_URI=mongodb+srv://kdrama:drama122@cluster0.2nwrn6k.mongodb.net/?appName=Cluster0
DB_NAME=tgbot


#------storage channel id for storing triggers and media files
STORAGE_CHANNEL_ID=-1002535767492

# ── Admin Access ──────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to run admin commands.
# Find your ID by messaging @userinfobot or @getidsbot
ADMIN_IDS=6244759828

# ── Feature Tuning ────────────────────────────────────────────────────────────
# Fuzzy match threshold (0–100). Higher = stricter. Recommended: 85–92.
FUZZY_THRESHOLD=90

# Max results returned by Show: search
MAX_SEARCH_RESULTS=5

# Triggers shown per page in /trigger_list
TRIGGERS_PER_PAGE=10

# Max messages to index per channel (set higher for large channels)
INDEX_LIMIT=5000
